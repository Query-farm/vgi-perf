# name: test/sql/bytes.test
# group: [vgi_perf]
#
# The overloaded `src` argument also accepts a BLOB of raw perf.data bytes (not
# just a path) — exercised here with the synthetic capture inlined as a from_hex
# literal, so the same decode runs entirely from a BLOB with no file on disk.

require-env VGI_PERF_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'perf' AS perf (TYPE vgi, LOCATION '${VGI_PERF_WORKER}');

statement ok
SET search_path = 'perf.main';

# Decode samples straight from a BLOB literal.
query III
SELECT ip, cpu, len(callchain)
FROM perf.main.samples(from_hex(''))
ORDER BY time
LIMIT 1;
----
4194560	2	2

# mmaps + meta also decode from the same BLOB.
query I
SELECT count(*) FROM perf.main.mmaps(from_hex(''));
----
2

query I
SELECT total_events FROM perf.main.meta(from_hex(''));
----
6

statement ok
USE memory;

statement ok
DETACH perf;
